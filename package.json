{
  "name": "esbuild-plugin-json-cleaner",
  "version": "0.1.3",
  "description": "esbuild plugin to cleanup JSON files",
  "keywords": [
    "esbuild",
    "json",
    "plugin"
  ],
  "homepage": "https://github.com/AFCMS/esbuild-plugin-json-cleaner",
  "bugs": {
    "url": "https://github.com/AFCMS/esbuild-plugin-json-cleaner/issues"
  },
  "license": "MIT",
  "author": {
    "name": "AFCMS",
    "email": "afcm.contact@gmail.com",
    "url": "https://afcms.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AFCMS/esbuild-plugin-json-cleaner.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@types/node": "^24.10.11",
    "bumpp": "^11.0.1",
    "esbuild": "^0.28.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.58.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "esbuild": "^0.27.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
