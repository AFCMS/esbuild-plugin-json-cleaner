{
    "compilerOptions": {
        "moduleResolution": "bundler",
        "module": "Preserve",
        "target": "ES2020",
        "lib": [
            "ES2020"
        ],
        "types": [
            "node"
        ],
        "outDir": "dist",
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationDir": "dist",
        "sourceMap": true
    },
    "files": [
        "./src/index.ts"
    ],
    "compileOnSave": false,
    "buildOnSave": false
}